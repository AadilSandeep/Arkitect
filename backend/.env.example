# =============================================================================
# Arkitect Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host/database?sslmode=require
DATABASE_URL=

# ── Supabase Auth ────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Found in: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# ── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENABLED=true

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# For production, set to your Vercel frontend URL only.
# CORS_ORIGINS=["https://your-app.vercel.app"]

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_GENERATE=10/minute
RATE_LIMIT_READ=100/minute
